# Copy to experiments/so101_trainswap/env/wsl.env and fill in (wsl.env is gitignored).
# Usage: from lerobot repo root: set -a && source experiments/so101_trainswap/env/wsl.env && set +a

# Raspberry Pi primitive server (no trailing /primitive)
PI_BASE_URL=http://192.168.1.50:8765

# Intel RealSense serial or device name (empty may use default device)
REALSENSE_SERIAL=

# OpenAI-compatible LLM (LM Studio default is often port 1234)
LM_BASE_URL=http://127.0.0.1:1234/v1
LM_MODEL=local-model

# CLIP: cuda or cpu
CLIP_DEVICE=cuda
